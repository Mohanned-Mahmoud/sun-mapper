# Everything below is optional — the app works with ZERO keys set,
# using free/no-key APIs (Open-Meteo for weather, Nominatim for geocoding,
# suncalc library for sun position, straight-line estimate for routing).

# Optional: more accurate routes/durations (free tier, no credit card)
# Sign up at https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# Temperature thresholds in Celsius (used to label legs Hot/Warm/Cool)
TEMP_HOT_THRESHOLD=32
TEMP_WARM_THRESHOLD=22
